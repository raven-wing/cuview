{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "packages": {
    ".": {
      "release-type": "simple",
      "extra-files": [
        {
          "type": "generic",
          "path": "gradle.properties",
          "search-version-regex": "VERSION_NAME=(?<version>[0-9]+\\.[0-9]+\\.[0-9]+)"
        }
      ]
    }
  }
}
